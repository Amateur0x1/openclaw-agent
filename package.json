{
  "name": "@amateur0x1/openclaw-agent",
  "version": "1.3.0",
  "description": "OpenClaw Agent Git Management Tool — version-control your agents with Git, sync across devices, and share with the community.",
  "description zh": "OpenClaw Agent Git 管理工具 — 将 agent 纳入 Git 版本控制，支持多端同步与社区分享。",
  "type": "module",
  "bin": {
    "openclaw-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "openclaw-agent",
    "agent",
    "git",
    "version-control",
    "sync",
    "multi-agent",
    "claude",
    "ai"
  ],
  "homepage": "https://github.com/amateur0x1/openclaw-agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/amateur0x1/openclaw-agent.git",
    "directory": "agents/amateur0x1/openclaw-agent"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "inquirer": "^9.2.15",
    "octokit": "^3.1.2",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "README_CN.md"
  ]
}
